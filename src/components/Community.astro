---
const { contributors } = Astro.props;
---

<section class="community">
  <h2 align="center">Community</h2><br><br>
  <div class="contributors">
    {contributors.map((c) => (
      <div class="contributor">
        <img src={c.avatar} alt={c.name} class="contributor-avatar" />
        <h3>{c.name}</h3>
        <p>{c.bio}</p>
      </div>
    ))}
  </div>
</section>

<style>
.community {
  margin: 4rem 0;
}
.contributors {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  justify-content: center; /* ini bikin semua .contributor rata tengah baris */
}
.contributor {
  text-align: center;
  width: 200px;
}
.contributor-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  object-fit: cover;
}
.contributor {
  display: flex;
  flex-direction: column;
  align-items: center;  /* anak di dalam .contributor di-center */
  text-align: center;
  width: 200px;
}
.contributor-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;    /* bulat */
  object-fit: cover;     /* supaya pas crop */
  margin-bottom: 1rem;   /* jarak ke nama */
}
</style>